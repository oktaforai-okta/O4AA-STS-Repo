# DevOps Agent Demo - Root .gitignore

# Environment variables (NEVER commit!)
.env
.env.*
!.env.example
.env.local
.env.*.local

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Logs
*.log
logs/
*.log.*

# Temporary files
*.tmp
*.temp
.cache/

# Python (backend)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/

# Node.js (frontend)
node_modules/
.pnp.*
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next/
out/
*.tsbuildinfo
next-env.d.ts

# Build outputs
/build
/dist

# Test coverage
coverage/
.nyc_output/
*.coverage

# Secrets and keys
*.pem
*.key
*.p12
*.pfx
id_rsa*
*.jwk

# Backup files
*.bak
*.backup
*~

# Package manager locks (optional - comment out if you want to commit them)
# package-lock.json
# yarn.lock

# Documentation build artifacts
docs/_build/
docs/.doctrees/
