# Next.js Frontend - .gitignore

# Environment variables - NEVER COMMIT!
.env
.env.*
!.env.local.example
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Dependencies
/node_modules
/.pnp
.pnp.js
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
.nyc_output

# Next.js
/.next/
/out/

# Production build
/build
/dist

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# Sentry
.sentryclirc

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# Secrets and keys - NEVER COMMIT!
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
id_rsa*
secrets.json

# Temporary files
*.tmp
*.temp
.cache/
.parcel-cache/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Storybook
storybook-static

# Turborepo
.turbo

# Mac
.AppleDouble
.LSOverride
